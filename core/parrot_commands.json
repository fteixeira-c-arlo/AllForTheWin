{
  "source": "Parrot AT / ISP console (abstract-backed; raw lines differ from E3 Wired / other ISPs).",
  "commands": [
    {"name": "build_info", "abstract": "version", "description": "Firmware / build (AGW)", "syntax": "build_info", "category": "isp", "shell": "build_info"},
    {"name": "get_firmware_version", "abstract": "get_firmware_version", "description": "Same as build_info (cross-platform abstract)", "syntax": "build_info", "category": "isp", "shell": "build_info"},
    {"name": "get_model_id", "abstract": "get_model_id", "description": "Model from build_info output", "syntax": "build_info", "category": "isp", "shell": "build_info"},
    {"name": "get_serial_number", "abstract": "get_serial_number", "description": "Serial number", "syntax": "GGET=sn", "category": "isp", "shell": "GGET=sn"},
    {"name": "get_device_info", "abstract": "get_device_info", "description": "Device info dump", "syntax": "RDPV", "category": "isp", "shell": "RDPV"},
    {"name": "device_info", "abstract": "info", "description": "Device info (info abstract)", "syntax": "RDPV", "category": "isp", "shell": "RDPV"},
    {"name": "bs_info", "abstract": "info", "description": "Basestation slice (same console as RDPV on Parrot)", "syntax": "RDPV", "category": "isp", "shell": "RDPV"},
    {"name": "factory_reset", "abstract": "factory_reset", "description": "Factory reset", "syntax": "factory_reset", "category": "isp", "shell": "factory_reset"},
    {"name": "reboot", "abstract": "reboot", "description": "Reboot via gateway", "syntax": "arlogw reboot", "category": "isp", "shell": "arlogw reboot"},
    {"name": "update_url", "abstract": "update url", "description": "Get or set FOTA update URL (no args = show)", "syntax": "update_url [url]", "category": "isp", "shell": "update_url"},
    {"name": "get_update_url", "abstract": "get_update_url", "description": "Read update URL (abstract alias)", "syntax": "update_url", "category": "isp", "shell": "update_url"},
    {"name": "update_refresh", "abstract": "update check", "description": "Refresh update metadata (no apply)", "syntax": "update_refresh", "category": "isp", "shell": "update_refresh"},
    {"name": "update_refresh_force", "abstract": "update apply", "description": "Refresh and trigger upgrade", "syntax": "update_refresh 1", "category": "isp", "shell": "update_refresh 1"},
    {"name": "refresh_update_rules", "abstract": "refresh_update_rules", "description": "Refresh OTA / update rules", "syntax": "update_refresh", "category": "isp", "shell": "update_refresh"},
    {"name": "migrate", "abstract": "migrate", "description": "Migrate to stage (dev|qa|staging|ftrial|prod)", "syntax": "migrate <stage>", "category": "isp", "shell": "migrate"},
    {"name": "migrate_run", "abstract": "migrate_environment", "description": "Migrate environment then reboot (abstract)", "syntax": "migrate <env>", "category": "isp", "shell": "migrate"},
    {"name": "get_current_environment", "abstract": "get_current_environment", "description": "Build / stage hint (best effort)", "syntax": "VERA", "category": "isp", "shell": "VERA"},
    {"name": "get_kv_item", "abstract": "get_kv_item", "description": "Read KV item", "syntax": "kvread -s <key>", "category": "kv", "shell": "kvread -s"},
    {"name": "set_kv_write", "abstract": "set_kv_item", "description": "kvwrite key value", "syntax": "kvwrite <key> <value>", "category": "kv", "shell": "kvwrite"},
    {"name": "kv_commit", "abstract": "set_kv_item", "description": "Commit KV after kvwrite", "syntax": "kvcommit", "category": "kv", "shell": "kvcommit"},
    {"name": "get_wifi_status", "abstract": "get_wifi_status", "description": "WiFi wlan0 status", "syntax": "ATW?", "category": "isp", "shell": "ATW?"},
    {"name": "ping", "abstract": "ping", "description": "Ping host (AT)", "syntax": "ATWI <host>", "category": "isp", "shell": "ATWI"},
    {"name": "caliget", "abstract": "mfg get", "description": "Generic get (GGET=field); use get_serial_number for sn", "syntax": "GGET=<field>", "category": "cali", "shell": "GGET="},
    {"name": "caliset", "abstract": "mfg set", "description": "Manufacturing cal write", "syntax": "(not on Parrot)", "category": "cali", "shell": "", "unsupported": true, "unsupported_message": "mfg set / caliset is not mapped on Parrot."},

    {"name": "tar_logs", "abstract": "log save", "description": "Archive logs before reset", "syntax": "(n/a)", "category": "logs", "shell": "", "unsupported": true, "unsupported_message": "tar_logs is not defined on Parrot; use factory_reset (underscore) instead of factory reset."},
    {"name": "tail_logs", "abstract": "tail_logs", "description": "Live logs", "syntax": "(n/a)", "category": "logs", "shell": "", "unsupported": true, "unsupported_message": "tail_logs is not available on Parrot UART; capture lfs:/log via ATFC if needed."},
    {"name": "pull_logs", "abstract": "log pull", "description": "Pull log archive", "syntax": "(n/a)", "category": "logs", "shell": "", "unsupported": true, "unsupported_message": "log pull is not available on Parrot."},
    {"name": "manual_ota", "abstract": "manual_ota", "description": "Manual OTA from URL", "syntax": "(n/a)", "category": "firmware", "shell": "", "unsupported": true, "unsupported_message": "manual_ota URL flow is not mapped on Parrot; use manual_upgrade <folder> in Advanced."},
    {"name": "stop_arlo_service", "abstract": "stop_arlo_service", "description": "Stop arlod", "syntax": "(n/a)", "category": "linux", "shell": "", "unsupported": true, "unsupported_message": "stop_arlo_service is not applicable on Parrot."},
    {"name": "connect_wifi", "abstract": "connect_wifi_ip", "description": "WiFi WPA2 connect", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "connect_wifi_ip is not mapped on Parrot; use raw ATW0/ATW1/ATWC if supported."},
    {"name": "wifi_connect", "abstract": "wifi connect", "description": "WiFi connect (abstract)", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "wifi connect is not mapped on Parrot."},
    {"name": "general_get_ip", "description": "Get IP after WiFi", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "general_get_ip is not mapped on Parrot."},
    {"name": "log_level", "abstract": "log level", "description": "Set log level", "syntax": "(n/a)", "category": "logs", "shell": "", "unsupported": true, "unsupported_message": "log level is not mapped on Parrot."},
    {"name": "get_boot_partition", "abstract": "get_boot_partition", "description": "Boot partition", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "get_boot_partition is not available on Parrot."},
    {"name": "set_boot_partition", "abstract": "set_boot_partition", "description": "Set boot partition", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "set_boot_partition is not available on Parrot."},
    {"name": "read_adc", "abstract": "read_adc", "description": "Read ADC", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "read_adc is not available on Parrot."},
    {"name": "read_lux", "abstract": "read_lux", "description": "Ambient light", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "read_lux is not available on Parrot."},
    {"name": "read_temperature", "abstract": "read_temperature", "description": "Temperature sensor", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "read_temperature is not available on Parrot."},
    {"name": "floodlight_on", "abstract": "floodlight_on", "description": "Floodlight on", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "floodlight_on is not available on Parrot."},
    {"name": "floodlight_off", "abstract": "floodlight_off", "description": "Floodlight off", "syntax": "(n/a)", "category": "isp", "shell": "", "unsupported": true, "unsupported_message": "floodlight_off is not available on Parrot."},

    {"name": "update_image", "description": "Force FW upgrade from URL", "syntax": "update_image <model_id> <version> <url>", "category": "firmware", "shell": "update_image"},
    {"name": "manual_upgrade", "description": "Manual FW upgrade from folder", "syntax": "manual_upgrade <folder>", "category": "firmware", "shell": "manual_upgrade"},
    {"name": "vera", "description": "Alternate build / version read", "syntax": "VERA", "category": "isp", "shell": "VERA"},
    {"name": "get_device_ap", "description": "Device info (AP mode, optional SN)", "syntax": "get_device [<sn>]", "category": "isp", "shell": "get_device"},
    {"name": "btyget_all", "description": "Battery info", "syntax": "BTYGET=all", "category": "device", "shell": "BTYGET=all"},
    {"name": "kvwrite_bs_update_url", "description": "Write OTA URL to KV (then kvcommit + reboot)", "syntax": "kvwrite KV_BS_UPDATE_URL <url>", "category": "kv", "shell": "kvwrite KV_BS_UPDATE_URL"},
    {"name": "atfl_lfs", "description": "Browse LFS root", "syntax": "ATFL=lfs:", "category": "filesystem", "shell": "ATFL=lfs:"},
    {"name": "atfc_capture", "description": "Capture file from device (e.g. entitlement)", "syntax": "ATFC=<path>", "category": "filesystem", "shell": "ATFC="},
    {"name": "bat_sim_enable", "description": "Battery sim on (1) / off (0); always disable after tests", "syntax": "bat_sim_enable 0|1", "category": "battery", "shell": "bat_sim_enable"},
    {"name": "batt_sim_perc", "description": "Set simulated battery %", "syntax": "batt_sim_perc <0~100>", "category": "battery", "shell": "batt_sim_perc"},
    {"name": "batt_sim_volt", "description": "Set simulated voltage (mV)", "syntax": "batt_sim_volt <0~5000>", "category": "battery", "shell": "batt_sim_volt"},
    {"name": "batt_sim_temp", "description": "Set simulated temp (°C)", "syntax": "batt_sim_temp <-30~80>", "category": "battery", "shell": "batt_sim_temp"},
    {"name": "batt_sim_curr", "description": "Set simulated current (mA)", "syntax": "batt_sim_curr <0~2000>", "category": "battery", "shell": "batt_sim_curr"}
  ]
}
